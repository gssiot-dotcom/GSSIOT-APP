{
  "expo": {
    "name": "GSS",
    "slug": "gss-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "gssapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },

    "icon": "./assets/images/blue_logo.png",
       
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/blue_logo.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.aiwd0113.gssapp"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0cdddbce-f795-44ed-af92-199e913f2ad1"
      }
    }
  }
}